# bubble sort
#     Bubble sort repeatedly steps through a slice and compares adjacent elements, swapping them if they are out of order. It continues to loop over the slice until the whole list is completely sorted. Here's the pseudocode:

#     Set swapping to True
#     Set end to the length of the input list
#     While swapping is True:
#         Set swapping to False
#         For i from the 2nd element to end:
#             If the (i-1)th element of the input list is greater than the ith element:
#                 Swap the (i-1)th element and the ith element
#                 Set swapping to True
#         Decrement end by one
#     Return the sorted list


def bubble_sort(nums: list[int]) -> list[int]:
    swapping = True 
    end = len(nums) - 1 
    while swapping: # o(n)
        swapping = False
        for i in range(end): # O(n)
            if nums[i] > nums[i + 1]:
                nums[i], nums[i + 1] = nums[i + 1], nums[i]
                swapping = True
        end -= 1

    return nums
print(bubble_sort([5, 1, 4, 2, 8, 3])) # [1, 2, 3, 4, 5, 8]

# Bubble Sort Big O:
#     Time Complexity:   
        # because in the worst case, we have to compare each element with every other element.
        # Best case: If the data is pre-sorted, bubble sort becomes really fast. 
            # O(n)  -> all are in order, so we only need to make one pass through the list to confirm that it's sorted.
        # Worst case: If the data is in reverse order, bubble sort becomes really slow (but still in the same complexity class as random data).
            # O(n^2)  ->are in reverse order, we have to compare each element with every other element, leading to n*(n-1)/2 comparisons, which simplifies to O(n^2).

#     Space Complexity: O(1)    

# However, it's one of the slowest sorting algorithms, and as a result is almost never used in practice.






